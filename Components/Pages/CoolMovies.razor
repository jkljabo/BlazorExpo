@page "/cool-movies"

@using BlazorCodeChallenge.Constants
@using BlazorCodeChallenge.Services

@inject IJSRuntime JS
@layout MovieTimeLayout

@inject AppState AppState
@implements IDisposable

@inject TMDBService TMDBService

<PageTitle>Cool Movies</PageTitle>

<div class="container-xxl py-3">
    <h1>
        <i class="bi bi-stars text-primary"></i>
        Cool Movie Listings
    </h1>
    <p class="lead italic">Browse the coolest movies in The Movie DataBase.</p>
    
    @if (coolMovies is null)
    {
        <div class="d-flex justify-content-center align-items-center">
            @if (isLoading)
            {
                <h2 class="text-muted">Loading cool movies...</h2>
            }
            else
            {
                <h2 class="text-muted">Failed to load cool movies...</h2>
            }
        </div>
    }
    else
    {
        <div class="row g-3 row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-lg-4">
            @foreach (var movie in coolMovies.Results)
            {
                <div class="col">
                    <MovieCard Movie="movie" />
                </div>
            }
        </div>
    }

</div>
