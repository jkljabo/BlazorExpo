@page "/movietime"

@using BlazorCodeChallenge.Constants
@using BlazorCodeChallenge.Services
@inject IJSRuntime JS
@layout MovieTimeLayout

@inject AppState AppState
@implements IDisposable

<PageTitle>Movie Time</PageTitle>

<!--Page Background-->
<div class="pageStyle h-100 d-flex justify-content-center">
    <div class="row row-cols-1 row-cols-xl-2 container-xxl h-100">
        <div class="col d-flex flex-column justify-content-xl-center order-last order-xl-first">
            <div class="title mt-3 mt-xl-0">
                Movie Time
            </div>
            <div class="subTitle">
                Movie Time is an app using data provided by
                <a href="https://www.themoviedb.org/" class="link-warning">The Movie DB</a> API.
                This app allows you to browse movies that are now playing in theatres,
                movies that are currently popular with TMDB users, save a list of your
                favorite movies, or search for movies by title.
            </div>
            <div class="mt-3">
                <h3>Try it Out Now!</h3>
                <div class="hstack gap-2">
                    <a href="movies" class="btn btn-movie-time-home">Movies</a>
                    <a href="cool-movies" class="btn btn-movie-time-home">Cool Movies</a>
                    <a href="favorite-movies" class="btn btn-movie-time-home">Favorite Movies</a>
                </div>
                @* <button type="button" class="rounded btn btn-primary">Try It Out!</button> *@
            </div>
            <div class="mt-3">
                Built with pride using:
                <div class="hstack my-2">
                    <div><i class="devicons devicon-blazor-original me-1"></i></div>
                    <div><i class="devicons devicon-csharp-plain me-1"></i></div>
                    <div><i class="devicons devicon-bootstrap-plain me-1"></i></div>
                    <div><i class="devicons devicon-javascript-plain me-1"></i></div>
                    <div><i class="devicons devicon-html5-plain me-1"></i></div>
                    <div><i class="devicons devicon-css3-plain me-1"></i></div>
                </div>
            </div>
        </div>
        <div class="col d-flex flex-column justify-content-center">
            <img src="/images/MovieTime/LandingPage800.png" class="img-fluid" />
            @* <img src="/images/MovieTime/MovieTime.jpg" class="img-fluid" /> *@
        </div>
    </div>
</div>



@code {
    protected override void OnInitialized()
    {
        AppState.SetFooterBrand(FooterBrands.MovieTime);
    }

    public void Dispose()
    {
        // nothing (preferred long-term)
    }
}
