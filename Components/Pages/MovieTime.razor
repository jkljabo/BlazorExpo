@page "/movietime"
@using BlazorCodeChallenge.Components.Services
@inject IJSRuntime JS
@layout HomeLayout

@inject FooterBrandService FooterBrandService
@implements IDisposable

<PageTitle>Movie Time</PageTitle>

<!--Page Background-->
<div class="pageStyle h-100 d-flex justify-content-center">
    <div class="row row-cols-1 row-cols-xl-2 container-xxl h-100">
        <div class="col d-flex flex-column justify-content-xl-center order-last order-xl-first">
            <div class="title mt-3 mt-xl-0">
                Movie Time
            </div>
            <div class="subTitle">
                Movie Time is an app using data provided by
                <a href="https://www.themoviedb.org/" class="link-warning">The Movie DB</a> API.
                This app allows you to browse movies that are now playing in theatres,
                movies that are currently popular with TMDB users, save a list of your
                favorite movies, or search for movies by title.
            </div>
            <div class="mt-3">
                <h3>Try it Out Now!</h3>
                <div class="hstack gap-2">
                    <a href="movies" class="btn btn-warning">Movies</a>
                    <a href="cool-movies" class="btn btn-warning">Cool Movies</a>
                    <a href="favorite-movies" class="btn btn-warning">Favorite Movies</a>
                </div>
                @* <button type="button" class="rounded btn btn-primary">Try It Out!</button> *@
            </div>
            <div class="mt-3">
                Built with pride using:
                <div class="hstack my-2">
                    <div><i class="devicons devicon-blazor-original colored me-1"></i></div>
                    <div><i class="devicons devicon-csharp-plain colored me-1"></i></div>
                    <div><i class="devicons devicon-bootstrap-plain colored me-1"></i></div>
                    <div><i class="devicons devicon-javascript-plain colored me-1"></i></div>
                    <div><i class="devicons devicon-html5-plain colored me-1"></i></div>
                    <div><i class="devicons devicon-css3-plain colored me-1"></i></div>
                </div>
            </div>
        </div>
        <div class="col d-flex flex-column justify-content-center">
            <img src="/images/MovieTime/LandingPage800.png" class="img-fluid" />
            @* <img src="/images/MovieTime/MovieTime.jpg" class="img-fluid" /> *@
        </div>
    </div>
</div>



@code {
    protected override void OnInitialized()
    {
        FooterBrandService.SetBrand(new FooterBrand
        {
            Label = "Powered By",

            Image = "/images/MovieTime/tmdb_long_logo.png",

            Width = 175,

            Height = 15,

            Alt = "The Movie Database",

            Url = "https://www.themoviedb.org/"
        });
    }

    public void Dispose()
    {
        FooterBrandService.Reset();
    }
}
