@page "/"
@inject IJSRuntime JS
@using BlazorCodeChallenge.Components.Services
@using BlazorCodeChallenge.Services
@layout HomeLayout

@inject AppState AppState
@implements IDisposable

<PageTitle>Blazor Code Challenges - Home</PageTitle>

<!--Page Background-->
<div class="pageStyle h-100 d-flex justify-content-center">
@* <div class="h-100 d-flex justify-content-center"> *@

    @* <h1>Hello, Jabo!</h1>
    Welcome to your new app. *@

    <div class="row row-cols-1 row-cols-xl-2 container-xxl h-100">
        <div class="col d-flex flex-column justify-content-xl-center order-last order-xl-first">

            <div class="title">Coding Challenge Built with Blazor</div>

            <div class="subTitle">Showcasing Modern Web Development Skills Through Classic Coding Challenges</div>

            <div class="mt-3">
                <h4>This week's challenge: Movie Time</h4>
                <p>Last week's challenge: <a href="/mortgagecalculator">Mortgage Calculator</a></p>
                <p>Past week's challenges: <a href="/fizzbuzzvalidation">Fizz Buzz (Validation)</a></p>
            </div>

            <div class="mt-3">
