@page "/weatherdashboard"
@using BlazorCodeChallenge.Components.Services
@using BlazorCodeChallenge.Services
@layout HomeLayout

@inject AppState AppState
@implements IDisposable

<PageTitle>Weather Dashboard</PageTitle>

<!--Page Background-->
<div class="pageStyle h-100 d-flex justify-content-center">
    
    <div class="row row-cols-1 row-cols-xl-2 container-xxl h-100">
        <div class="col d-flex flex-column justify-content-xl-center order-last order-xl-first">

            @* <h3>National Weather Service Dashboard</h3> *@
            <div class="title">NWS Dashboard</div>

            <div class="subTitle">Showcasing Modern Web Development Skills Through the use of public APIs</div>

            <div class="mt-3">
                <h4>What is the National Weather Service Dashboard?</h4>
                <p>This is a customizable dashboard based on the template provided by Visual Studio built out to connect to the National Weather Service API. The user can enter address or Latitude and Longitude information and the dashboard with provide you with the current weather condition and radar view as well as a 5 day forcast for your area.</p>
            </div>

            <div class="card p-3 mb-3">

                <div class="row">

                    <div class="col-md-4">
                        <label>City</label>
                        <input class="form-control" @bind="City" />
                    </div>

                    <div class="col-md-2">
                        <label>State</label>
                        <input class="form-control" @bind="State" />
                    </div>

                    <div class="col-md-3">
                        <label>Zip Code</label>
                        <input class="form-control" @bind="ZipCode" />
                    </div>

                </div>

                <hr />

                <div class="row">

                    <div class="col-md-3">
                        <label>Latitude</label>
                        <input class="form-control" @bind="Latitude" />
                    </div>

                    <div class="col-md-3">
                        <label>Longitude</label>
                        <input class="form-control" @bind="Longitude" />
                    </div>

                </div>

                <button class="btn btn-primary mt-3"
                        @onclick="LoadWeather">
                    Get Weather
                </button>

            </div>

            @if (CurrentPeriod != null)
            {
                <div class="card p-3 mb-3">

                    <h4>Current Conditions</h4>

                    <p>
                        <strong>@CurrentPeriod.Name</strong>
                    </p>

                    <p>
                        Temperature:
                        @CurrentPeriod.Temperature
                        @CurrentPeriod.TemperatureUnit
                    </p>

                    <p>
                        Wind:
                        @CurrentPeriod.WindSpeed
                        @CurrentPeriod.WindDirection
                    </p>

                    <p>
                        @CurrentPeriod.ShortForecast
                    </p>

                </div>

                <div class="card p-3 mb-3">

                    <h4>Radar</h4>

                    <img class="img-fluid"
                         src="@RadarUrl"
                         alt="Radar Image" />

                </div>

                <div class="card p-3">

                    <h4>5 Day Forecast</h4>

                    <table class="table">

                        <thead>
                            <tr>
                                <th>Period</th>
                                <th>Temp</th>
                                <th>Forecast</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var period in ForecastPeriods.Take(10))
                            {
                                <tr>
                                    <td>@period.Name</td>
                                    <td>
                                        @period.Temperature°
                                        @period.TemperatureUnit
                                    </td>
                                    <td>@period.ShortForecast</td>
                                </tr>
                            }

                        </tbody>

                    </table>

                </div>
            }
            </div>
            <div class="col d-flex flex-column justify-content-center">
            <img src="/images/NWSDashboard/NWSLogo.png" class="img-fluid" />
            </div>
            
        </div>
</div>